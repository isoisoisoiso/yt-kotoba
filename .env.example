# yt-kotoba runs entirely without API keys.
# Generation (X thread / note article) is delegated to whatever agent
# invokes the skill (Claude Code, Cursor, your own LLM pipe).
#
# These variables are OPTIONAL — only override if you need to.

# Whisper model (default: large-v3). Smaller = faster but less accurate.
# Options: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=large-v3

# faster-whisper compute type (CUDA only). Default: float16.
# Use int8 to fit on smaller GPUs (~5GB VRAM), or float32 for max precision.
WHISPER_COMPUTE_TYPE=float16

# faster-whisper device. Default: cuda (auto-fallback to cpu/int8 if unavailable).
WHISPER_DEVICE=cuda
